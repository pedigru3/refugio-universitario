generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String  @id @default(uuid())
  username        String  @unique
  name            String
  course          String
  education_level String
  email           String? @unique
  avatar_url      String?
  role            String?
  cellphone       String?
  birthday        DateTime?
  expires_at      DateTime? @default(now())

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  Scheduling Scheduling[]
  decks               Deck[]
  event_registrations EventRegistration[]


  @@map("users")
}

model Account {
  id                   String    @id @default(cuid())
  user_id              String
  provider_type        String
  provider_id          String
  provider_account_id  String
  refresh_token        String?
  access_token         String?
  access_token_expires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([provider_id, provider_account_id])
  @@map("accounts")
}

model Session {
  id            String   @id @default(cuid())
  user_id       String
  expires       DateTime
  session_token String   @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("sessions")
}

model Table {
  id          String @id @default(uuid())
  table_name  String
  chair_count Int

  created_at DateTime @default(now())

  schedulings Scheduling[]

  @@map("tables")
}

model Scheduling {
  id   String   @id @default(uuid())
  date DateTime

  created_at DateTime  @default(now())
  check_in   DateTime?
  check_out  DateTime?

  spent_time_in_minutes Int @default(60)

  table Table? @relation(fields: [table_id], references: [id])
  user  User   @relation(fields: [user_id], references: [id])

  user_id  String
  table_id String?

  @@index([user_id])
  @@map("schedulings")
}

model AvailableSchedule {
  week_day               Int @unique
  time_start_in_minutes  Int
  time_end_in_minutes    Int
  start_block_in_minutes Int @default(0)
  end_block_in_minutes   Int @default(0)

  start_day DateTime?
  final_day DateTime?

  @@map("available_schedules")
}

model BlockedDates {
  id   String   @id @default(uuid())
  date DateTime
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("system_configs")
}

model Deck {
  id          String   @id @default(uuid())
  title       String
  description String?
  user_id     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  flashcards Flashcard[]

  @@map("decks")
}

model Flashcard {
  id          String   @id @default(uuid())
  front       String
  back        String
  deck_id     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Spaced Repetition System (SRS) fields
  next_review DateTime @default(now())
  interval    Int      @default(0) // Interval in minutes
  ease_factor Float    @default(2.5)
  repetitions Int      @default(0)

  deck Deck @relation(fields: [deck_id], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

model Event {
  id           String   @id @default(uuid())
  title        String
  description  String?
  image_url    String?
  date         DateTime
  max_capacity Int      @default(20)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  created_at DateTime @default(now())

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@map("event_registrations")
}
